---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { Image } from 'astro:assets';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import QccbotCover from '../assets/qccbot-cover.png';
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			main {
				width: 1080px;
			}
			.hero {
				display: grid;
				grid-template-columns: minmax(0, 1.05fr) minmax(320px, 0.95fr);
				gap: 2.5rem;
				align-items: center;
				padding: 1.5rem 0 2.5rem;
			}
			.eyebrow {
				margin: 0 0 0.75rem;
				color: var(--accent);
				font-size: 0.9rem;
				font-weight: 700;
				letter-spacing: 0;
				text-transform: uppercase;
			}
			.hero h1 {
				margin-bottom: 1rem;
				font-size: 3.1rem;
			}
			.hero-copy {
				font-size: 1.15rem;
				color: rgb(var(--gray-dark));
			}
			.hero-actions {
				display: flex;
				flex-wrap: wrap;
				gap: 0.8rem;
				margin-top: 1.5rem;
			}
			.button {
				display: inline-flex;
				align-items: center;
				justify-content: center;
				min-height: 2.75rem;
				padding: 0 1rem;
				border: 1px solid var(--accent);
				border-radius: 6px;
				text-decoration: none;
				font-weight: 700;
			}
			.button.primary {
				background: var(--accent);
				color: white;
			}
			.button.secondary {
				background: white;
				color: var(--accent);
			}
			.hero-media img {
				width: 100%;
				box-shadow: var(--box-shadow);
			}
			.metric-row,
			.capability-grid,
			.workflow-grid,
			.article-grid {
				display: grid;
				gap: 1rem;
			}
			.metric-row {
				grid-template-columns: repeat(4, 1fr);
				margin: 0 0 2.5rem;
			}
			.metric,
			.capability,
			.workflow,
			.article-link {
				border: 1px solid rgb(var(--gray-light));
				border-radius: 8px;
				background: white;
				padding: 1rem;
			}
			.metric strong {
				display: block;
				color: rgb(var(--black));
				font-size: 1.2rem;
			}
			.metric span {
				display: block;
				color: rgb(var(--gray));
				font-size: 0.9rem;
				line-height: 1.45;
			}
			.capability-grid {
				grid-template-columns: repeat(3, 1fr);
			}
			.workflow-grid {
				grid-template-columns: repeat(2, 1fr);
			}
			.article-grid {
				grid-template-columns: repeat(3, 1fr);
				margin-top: 1rem;
			}
			.capability h3,
			.workflow h3,
			.article-link h3 {
				font-size: 1.1rem;
			}
			.capability p,
			.workflow p,
			.article-link p {
				margin: 0;
				color: rgb(var(--gray));
				font-size: 0.96rem;
				line-height: 1.55;
			}
			.article-link {
				color: inherit;
				text-decoration: none;
			}
			.article-link:hover h3 {
				color: var(--accent);
			}
			section {
				margin-top: 2.5rem;
			}
			@media (max-width: 860px) {
				.hero,
				.metric-row,
				.capability-grid,
				.workflow-grid,
				.article-grid {
					grid-template-columns: 1fr;
				}
				.hero h1 {
					font-size: 2.2rem;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<div>
					<p class="eyebrow">AI 驱动的云手机运营</p>
					<h1>QCCBot 把云手机变成 AI 自动化工作台。</h1>
					<p class="hero-copy">
						QCCBot 将独立 Android 云手机、AI 脚本引擎、AI Guardian 任务监控和多平台脚本库整合到一个控制台，帮助团队更轻松地管理移动端重复任务。
					</p>
					<div class="hero-actions">
						<a class="button primary" href="https://www.qccbot.com/">访问 QCCBot 官网</a>
						<a class="button secondary" href="/blog/">阅读中文博客</a>
					</div>
				</div>
				<div class="hero-media">
					<Image
						src={QccbotCover}
						width={760}
						height={506}
						alt="QCCBot cloud phone management platform"
						loading="eager"
					/>
				</div>
			</section>

			<div class="metric-row" aria-label="QCCBot 平台亮点">
				<div class="metric">
					<strong>AI 脚本</strong>
					<span>把日常手机操作目标转成可复用、可调整的自动化流程。</span>
				</div>
				<div class="metric">
					<strong>任务监控</strong>
					<span>发现任务卡住、失败或界面变化，减少人工逐台检查。</span>
				</div>
				<div class="metric">
					<strong>云手机</strong>
					<span>为不同 App、账号、项目提供独立 Android 环境。</span>
				</div>
				<div class="metric">
					<strong>脚本库</strong>
					<span>覆盖 TikTok、YouTube、小红书、微博、LinkedIn 等常见任务。</span>
				</div>
			</div>

			<section>
				<h2>为移动端运营准备的 AI 能力</h2>
				<div class="capability-grid">
					<div class="capability">
						<h3>AI 脚本引擎</h3>
						<p>
							把运营目标转成脚本步骤，从模板开始测试，再根据 App 页面变化持续调整。
						</p>
					</div>
					<div class="capability">
						<h3>AI Guardian 任务监控</h3>
						<p>
							监控任务状态，发现卡住的云手机，帮助团队更快定位需要人工处理的问题。
						</p>
					</div>
					<div class="capability">
						<h3>云手机上下文</h3>
						<p>
							结合设备分组、App 状态、任务日志和远程控制，让自动化结果更容易复盘。
						</p>
					</div>
				</div>
			</section>

			<section>
				<h2>From script store to repeatable operations</h2>
				<div class="workflow-grid">
					<div class="workflow">
						<h3>Multi-platform task templates</h3>
						<p>
							QCCBot's script store includes workflows for TikTok, YouTube, Xiaohongshu, Weibo,
							LinkedIn, and utility operations such as cache clearing, search, posting, and
							status updates.
						</p>
					</div>
					<div class="workflow">
						<h3>Batch device orchestration</h3>
						<p>
							Group cloud phones by campaign, region, client, or account type, then run,
							observe, and tune tasks across isolated Android instances from one dashboard.
						</p>
					</div>
				</div>
			</section>

			<section>
				<h2>Latest AI automation guides</h2>
				<div class="article-grid">
					<a class="article-link" href="/blog/qccbot-ai-script-engine-cloud-phone-automation/">
						<h3>AI Script Engine</h3>
						<p>How QCCBot helps teams move from manual scripts to AI-assisted workflows.</p>
					</a>
					<a class="article-link" href="/blog/qccbot-ai-guardian-engine-reliability/">
						<h3>AI Guardian Engine</h3>
						<p>Why task recovery matters when cloud phone automation runs at scale.</p>
					</a>
					<a class="article-link" href="/blog/qccbot-social-media-script-library/">
						<h3>Script library</h3>
						<p>How reusable templates turn social app workflows into repeatable operations.</p>
					</a>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>
