---
const today = new Date();
---

<footer>
	<div class="footer-brand">
		<img src="/qccbot-icon.png" alt="" width="36" height="36" />
		<span>&copy; {today.getFullYear()} QCCBot. All rights reserved.</span>
	</div>
	<div class="social-links">
		<a class="icon-link" href="https://www.qccbot.com/" target="_blank">
			<span class="sr-only">Visit QCCBot website</span>
			<img src="/qccbot-icon.png" alt="" width="32" height="32" />
		</a>
		<a href="/blog">
			<span class="sr-only">Read QCCBot blog</span>
			<svg viewBox="0 0 16 16" aria-hidden="true" width="32" height="32"
				><path
					fill="currentColor"
					d="M3 1.5h8.5L14 4v10.5H3A1.5 1.5 0 0 1 1.5 13V3A1.5 1.5 0 0 1 3 1.5Zm0 1.25a.25.25 0 0 0-.25.25v10c0 .14.11.25.25.25h9.75V4.5H11a1 1 0 0 1-1-1V2.75H3Zm2 3h6v1.2H5v-1.2Zm0 2.5h6v1.2H5v-1.2Zm0 2.5h4v1.2H5v-1.2Z"
				></path></svg
			>
		</a>
	</div>
</footer>
<style>
	footer {
		padding: 2em 1em 6em 1em;
		background: linear-gradient(var(--gray-gradient)) no-repeat;
		color: rgb(var(--gray));
		text-align: center;
	}
	.footer-brand {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 0.6rem;
	}
	.footer-brand img,
	.icon-link img {
		display: block;
		border-radius: 0;
	}
	.social-links {
		display: flex;
		justify-content: center;
		gap: 1em;
		margin-top: 1em;
	}
	.social-links a {
		text-decoration: none;
		color: rgb(var(--gray));
	}
	.social-links a:hover {
		color: rgb(var(--gray-dark));
	}
</style>
