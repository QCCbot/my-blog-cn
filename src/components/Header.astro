---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';

const englishHref = new URL(Astro.url.pathname, 'https://blog.qccbot.com').toString();
---

<header>
	<nav>
		<h2>
			<a class="brand" href="/">
				<img src="/qccbot-icon.png" alt="" width="32" height="32" />
				<span>{SITE_TITLE}</span>
			</a>
		</h2>
		<div class="internal-links">
			<HeaderLink href="/">首页</HeaderLink>
			<HeaderLink href="/blog">博客</HeaderLink>
			<HeaderLink href="/about">关于</HeaderLink>
			<div class="language-switch" aria-label="语言切换">
				<span class="language-option active" aria-current="true">中</span>
				<a class="language-option" href={englishHref}>EN</a>
			</div>
		</div>
		<div class="social-links">
			<a class="telegram-link" href="https://t.me/QCCbot_cloudphone" target="_blank" rel="noopener noreferrer">
				<span class="sr-only">通过 Telegram 联系 QCCBot 客服</span>
				<svg viewBox="0 0 24 24" aria-hidden="true" width="30" height="30">
					<path
						fill="currentColor"
						d="M21.7 3.6c.3-1-.6-1.4-1.3-1.1L2.7 9.3c-1.2.5-1.2 1.2-.2 1.5l4.5 1.4 1.7 5.3c.2.6.1.8.7.8.5 0 .7-.2 1-.5l2.4-2.3 5 3.7c.9.5 1.5.3 1.8-.9l3.2-15.1ZM7.7 11.8l10.5-6.6c.5-.3.9-.1.5.2l-8.5 7.7-.3 3.2-1.7-5 .1.1-.6.4Z"
					></path>
				</svg>
			</a>
			<a class="icon-link" href="https://www.qccbot.com/" target="_blank">
				<span class="sr-only">访问 QCCBot 官网</span>
				<img src="/qccbot-icon.png" alt="" width="32" height="32" />
			</a>
			<a href="/blog">
				<span class="sr-only">阅读 QCCBot 博客</span>
				<svg viewBox="0 0 16 16" aria-hidden="true" width="32" height="32"
					><path
						fill="currentColor"
						d="M3 1.5h8.5L14 4v10.5H3A1.5 1.5 0 0 1 1.5 13V3A1.5 1.5 0 0 1 3 1.5Zm0 1.25a.25.25 0 0 0-.25.25v10c0 .14.11.25.25.25h9.75V4.5H11a1 1 0 0 1-1-1V2.75H3Zm2 3h6v1.2H5v-1.2Zm0 2.5h6v1.2H5v-1.2Zm0 2.5h4v1.2H5v-1.2Z"
					></path></svg
				>
			</a>
		</div>
	</nav>
</header>
<style>
	header {
		position: sticky;
		top: 0;
		z-index: 1000;
		margin: 0;
		padding: 0 1em;
		border-bottom: 1px solid rgba(223, 232, 239, 0.85);
		background: rgba(255, 255, 255, 0.94);
		box-shadow: 0 2px 12px rgba(var(--black), 6%);
		backdrop-filter: saturate(180%) blur(14px);
		-webkit-backdrop-filter: saturate(180%) blur(14px);
	}
	:global(html) {
		scroll-padding-top: 5rem;
	}
	h2 {
		margin: 0;
		font-size: 1em;
	}

	h2 a,
	h2 a.active {
		text-decoration: none;
	}
	.brand {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
	}
	.brand img,
	.icon-link img {
		display: block;
		border-radius: 0;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
	}
	.internal-links {
		display: flex;
		align-items: center;
		white-space: nowrap;
	}
	nav a {
		padding: 1em 0.5em;
		color: var(--black);
		border-bottom: 4px solid transparent;
		text-decoration: none;
	}
	nav a.active {
		text-decoration: none;
		border-bottom-color: var(--accent);
	}
	.social-links,
	.social-links a {
		display: flex;
		align-items: center;
	}
	.social-links {
		gap: 0.45rem;
	}
	.language-switch {
		display: inline-flex;
		align-items: center;
		gap: 0;
		margin-left: 0.7rem;
		background: transparent;
	}
	.language-option {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 1em 0.42rem;
		border: 0;
		border-bottom: 4px solid transparent;
		color: #5b6670;
		font-size: 0.95rem;
		font-weight: 700;
		line-height: 1;
		text-decoration: none;
	}
	.language-option + .language-option {
		border-left: 1px solid rgba(31, 50, 65, 0.18);
	}
	.language-option.active {
		color: var(--black);
		border-bottom-color: var(--accent);
		font-weight: 900;
	}
	.telegram-link {
		color: #229ed9;
	}
	.telegram-link:hover {
		color: var(--accent);
	}
	@media (max-width: 720px) {
		header {
			padding: 0 0.6em;
		}
		.brand span {
			display: none;
		}
		nav {
			gap: 0.5rem;
			justify-content: flex-start;
		}
		.internal-links {
			margin-left: 0.25rem;
			justify-content: flex-start;
		}
		nav a {
			padding-right: 0.35em;
			padding-left: 0.35em;
			font-size: 0.95rem;
		}
		.language-switch {
			margin-left: 0.25rem;
		}
		.language-option {
			padding-right: 0.28rem;
			padding-left: 0.28rem;
			font-size: 0.85rem;
		}
		.social-links {
			margin-left: auto;
			gap: 0.2rem;
		}
		.social-links .icon-link,
		.social-links a[href='/blog'] {
			display: none;
		}
	}
</style>
