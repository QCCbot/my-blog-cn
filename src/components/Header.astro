---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';

const englishHref = new URL(Astro.url.pathname, 'https://blog.qccbot.com').toString();
---

<header>
	<nav>
		<h2>
			<a class="brand" href="/">
				<img src="/qccbot-icon.png" alt="" width="32" height="32" />
				<span>{SITE_TITLE}</span>
			</a>
		</h2>
		<div class="internal-links">
			<HeaderLink href="/">首页</HeaderLink>
			<HeaderLink href="/blog">博客</HeaderLink>
			<HeaderLink href="/about">关于</HeaderLink>
		</div>
		<div class="social-links">
			<a class="language-link" href={englishHref}>EN</a>
			<a class="icon-link" href="https://www.qccbot.com/" target="_blank">
				<span class="sr-only">访问 QCCBot 官网</span>
				<img src="/qccbot-icon.png" alt="" width="32" height="32" />
			</a>
			<a href="/blog">
				<span class="sr-only">阅读 QCCBot 博客</span>
				<svg viewBox="0 0 16 16" aria-hidden="true" width="32" height="32"
					><path
						fill="currentColor"
						d="M3 1.5h8.5L14 4v10.5H3A1.5 1.5 0 0 1 1.5 13V3A1.5 1.5 0 0 1 3 1.5Zm0 1.25a.25.25 0 0 0-.25.25v10c0 .14.11.25.25.25h9.75V4.5H11a1 1 0 0 1-1-1V2.75H3Zm2 3h6v1.2H5v-1.2Zm0 2.5h6v1.2H5v-1.2Zm0 2.5h4v1.2H5v-1.2Z"
					></path></svg
				>
			</a>
		</div>
	</nav>
</header>
<style>
	header {
		margin: 0;
		padding: 0 1em;
		background: white;
		box-shadow: 0 2px 8px rgba(var(--black), 5%);
	}
	h2 {
		margin: 0;
		font-size: 1em;
	}

	h2 a,
	h2 a.active {
		text-decoration: none;
	}
	.brand {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
	}
	.brand img,
	.icon-link img {
		display: block;
		border-radius: 0;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
	}
	nav a {
		padding: 1em 0.5em;
		color: var(--black);
		border-bottom: 4px solid transparent;
		text-decoration: none;
	}
	nav a.active {
		text-decoration: none;
		border-bottom-color: var(--accent);
	}
	.social-links,
	.social-links a {
		display: flex;
		align-items: center;
	}
	.language-link {
		justify-content: center;
		min-width: 2.6rem;
		height: 2rem;
		margin-right: 0.25rem;
		border: 1px solid rgb(var(--gray-light));
		border-radius: 999px;
		font-size: 0.9rem;
		font-weight: 700;
	}
	.language-link:hover {
		border-color: var(--accent);
	}
	@media (max-width: 720px) {
		.social-links a:not(.language-link) {
			display: none;
		}
	}
</style>
